{
  "version": 1,
  "default": "ask",
  "rules": [
    { "tools": ["@file(**/.ssh/**)"], "action": "deny", "message": ".ssh access denied" },
    { "tools": ["@file_read"], "action": "allow" },
    { "tools": ["@file_write"], "action": "allow", "in_workspace": true },
    { "tools": ["@file_write"], "action": "deny", "in_workspace": false, "message": "writes outside workspace are denied" },
    { "tools": ["@shell"], "action": "allow" },
    { "tools": ["WebFetch"], "action": "allow" }
  ]
}
